service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "NitishSainiG@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isSalesperson() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'salesperson';
    }

    function canAccessLead(leadData) {
      return isAdmin() || (isAuthenticated() && leadData.assignedTo == request.auth.uid);
    }

    function isAdminEmail(email) {
      return email == "NitishSainiG@gmail.com";
    }

    // User Profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && (
        (isAdminEmail(request.resource.data.email) && request.resource.data.role == 'admin') ||
        (!isAdminEmail(request.resource.data.email) && request.resource.data.role == 'salesperson')
      );
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role);
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if canAccessLead(resource.data);
      allow delete: if isAdmin();
    }

    // Deals
    match /deals/{dealId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
